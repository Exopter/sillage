# Copy this file to .kamal/secrets and fill local values before deploying.
# .kamal/secrets is intentionally ignored by Git.

# Required by Rails credentials in production.
RAILS_MASTER_KEY=$(cat config/master.key)

# Dummy credential for the private no-auth registry bound to 127.0.0.1 on the VPS.
KAMAL_REGISTRY_PASSWORD=registry

# Optional browser-safe Cesium ion token for photorealistic 3D tiles.
CESIUM_ION_TOKEN=
