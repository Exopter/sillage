# Copy this file to .kamal/secrets before deploying.
# Keep real values in .env.deploy.local; .kamal/secrets is only a Kamal bridge.

# Required by Rails credentials in production.
RAILS_MASTER_KEY=$RAILS_MASTER_KEY

# Dummy credential for the private no-auth registry bound to 127.0.0.1 on the VPS.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Optional browser-safe Cesium ion token for photorealistic 3D tiles.
CESIUM_ION_TOKEN=$CESIUM_ION_TOKEN

# HTTP Basic Auth for the public landing host.
EXOPTER_OS_LANDING_BASIC_AUTH_USERNAME=$EXOPTER_OS_LANDING_BASIC_AUTH_USERNAME
EXOPTER_OS_LANDING_BASIC_AUTH_PASSWORD=$EXOPTER_OS_LANDING_BASIC_AUTH_PASSWORD

# Postmark delivery token. Required only when EMAIL_ENABLED=true.
POSTMARK_SERVER_TOKEN=$POSTMARK_SERVER_TOKEN
