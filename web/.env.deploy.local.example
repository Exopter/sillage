# Copy to `.env.deploy.local`, then fill local deployment values.
# This file is safe to commit. `.env.deploy.local` is ignored by Git.

RAILS_MASTER_KEY=
KAMAL_REGISTRY_PASSWORD=
CESIUM_ION_TOKEN=

SILLAGE_LANDING_HOSTS=exopter.com
SILLAGE_OS_HOSTS=os.exopter.com
SILLAGE_LANDING_BASIC_AUTH_USERNAME=
SILLAGE_LANDING_BASIC_AUTH_PASSWORD=

EMAIL_ENABLED=false
MAIL_FROM=
MAIL_FROM_NAME=Exopter
MAIL_REPLY_TO=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=

# Ops industrialization flags. Keep false until backup runbooks are wired.
BACKUPS_ENABLED=false
MONITORING_ENABLED=false
