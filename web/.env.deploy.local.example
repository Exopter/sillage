# Copy to `.env.deploy.local`, then fill local deployment values.
# This file is safe to commit. `.env.deploy.local` is ignored by Git.

RAILS_MASTER_KEY=
KAMAL_REGISTRY_PASSWORD=
CESIUM_ION_TOKEN=

SILLAGE_LANDING_HOSTS=sillage.wild.eu
SILLAGE_OS_HOSTS=os.sillage.wild.eu

# Ops industrialization flags. Keep false until backup runbooks are wired.
BACKUPS_ENABLED=false
MONITORING_ENABLED=false
