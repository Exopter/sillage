<% content_for :title, @function.name %>
<header class="workspace-header"><div><span class="section-eyebrow"><%= @function.code %></span><h1><%= @function.name %></h1><p><%= @function.description %></p></div><div class="workspace-actions"><%= link_to "Edit", edit_core_function_path(@function), class: "button-secondary" %><%= link_to "Back", core_functions_path, class: "button-secondary" %></div></header>
<section class="workspace-panel"><h2>Parts</h2><% if @parts.any? %><div class="workspace-list"><% @parts.each do |part| %><%= link_to hangar_part_path(part), class: "workspace-list-row" do %><span><strong><%= part.internal_number %></strong><small><%= part.display_name %></small></span><span><%= part.state.titleize %></span><% end %><% end %></div><% else %><div class="workspace-empty">No part uses this function.</div><% end %></section>
