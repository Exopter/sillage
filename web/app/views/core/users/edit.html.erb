<% content_for :title, "Edit user" %>

<section class="core-users">
  <div class="core-users-header">
    <div>
      <span class="section-eyebrow">Sillage Core</span>
      <h1>Edit user</h1>
      <p><%= @user.email_address %></p>
    </div>
  </div>

  <section class="core-panel">
    <%= form_with model: @user, url: core_user_path(@user), method: :patch, class: "core-form" do |form| %>
      <label>
        <span>Role</span>
        <%= form.select :role, User::ROLES.map { |role| [role.titleize, role] } %>
      </label>
      <%= form.submit "Save user", class: "button-primary" %>
      <%= link_to "Back", core_users_path, class: "authentication-link" %>
    <% end %>
  </section>
</section>
