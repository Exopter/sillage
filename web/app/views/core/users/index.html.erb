<% content_for :title, "Users" %>

<section class="core-users">
  <div class="core-users-header">
    <div>
      <span class="section-eyebrow">Sillage Core</span>
      <h1>Users</h1>
    </div>
    <%= link_to "Functions", core_functions_path, class: "button-secondary" %>
  </div>

  <div class="core-users-grid">
    <section class="core-panel">
      <h2>Invite user</h2>
      <%= form_with model: @user, url: core_users_path, class: "core-form" do |form| %>
        <label>
          <span>Email</span>
          <%= form.email_field :email_address, required: true %>
        </label>
        <label>
          <span>Role</span>
          <%= form.select :role, User::ROLES.map { |role| [role.titleize, role] } %>
        </label>
        <%= form.submit "Send invitation", class: "button-primary" %>
      <% end %>
    </section>

    <section class="core-panel is-wide">
      <h2>Directory</h2>
      <div class="core-user-list">
        <% @users.each do |user| %>
          <article class="core-user-row">
            <div>
              <strong><%= user.email_address %></strong>
              <span><%= user.role.titleize %></span>
            </div>
            <div class="core-user-status">
              <% if user.disabled? %>
                <span class="status-pill is-disabled">Disabled</span>
              <% elsif user.invitation_pending? %>
                <span class="status-pill is-pending">Invited</span>
              <% else %>
                <span class="status-pill is-active">Active</span>
              <% end %>
              <% if user.admin? %>
                <span class="status-pill"><%= user.totp_configured? ? "2FA ready" : "2FA required" %></span>
              <% end %>
            </div>
            <div class="core-user-actions">
              <%= link_to "Edit", edit_core_user_path(user), class: "button-secondary" %>
              <% if user.invitation_pending? %>
                <%= button_to "Resend", resend_invitation_core_user_path(user), method: :post, class: "button-secondary" %>
              <% end %>
              <% if user.disabled? %>
                <%= button_to "Enable", enable_core_user_path(user), method: :patch, class: "button-secondary" %>
              <% else %>
                <%= button_to "Disable", disable_core_user_path(user), method: :patch, class: "button-secondary" %>
              <% end %>
              <% if user.totp_configured? %>
                <%= button_to "Reset 2FA", reset_two_factor_core_user_path(user), method: :patch, class: "button-secondary" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</section>
