<% content_for :title, "Sign in" %>

<div class="authentication-header">
  <span>Sillage</span>
  <h1>Sign in</h1>
</div>

<%= form_with url: session_path, class: "authentication-form" do |form| %>
  <label>
    <span>Email</span>
    <%= form.email_field :email_address, autocomplete: "username", required: true, autofocus: true %>
  </label>

  <label>
    <span>Password</span>
    <%= form.password_field :password, autocomplete: "current-password", required: true %>
  </label>

  <%= form.submit "Sign in", class: "button-primary" %>
<% end %>

<%= link_to "Reset password", new_password_path, class: "authentication-link" %>
